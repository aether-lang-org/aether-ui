import build
import aether
import aether (source, output, no_closure_regen, lib)
import aetherui (ui_backend)

main() {
    b = build.start()
    root = build._get(b, "root")
    aether.program(b) {
        source("tumbling_cube.ae")
        output("tumbling_cube")
        lib("${root}")
        no_closure_regen()
        ui_backend(root)
    }
    return 0
}
