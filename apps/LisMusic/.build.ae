// LisMusic — aether-ui toolkit app, built as its own cached aeb node.
// A port of SLTwitness's LisMusic (Qt6/QML) — see README.md.
import build
import aether
import aether (source, output, no_closure_regen)
import aetherui (ui_backend)

main() {
    b = build.start()
    root = build._get(b, "root")
    aether.program(b) {
        source("lismusic.ae")
        output("LisMusic")
        no_closure_regen()
        ui_backend(root)
    }
    return 0
}
