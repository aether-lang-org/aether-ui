// vg_tooltip — aether-ui vg example, built as its own cached aeb node.
import build
import aether
import aether (source, output, no_closure_regen, lib)
import aetherui (ui_backend)

main() {
    b = build.start()
    root = build._get(b, "root")
    aether.program(b) {
        source("vg_tooltip.ae")
        output("vg_tooltip")
        lib("${root}")               // so `import vg.*` resolves at the repo root
        no_closure_regen()
        ui_backend(root)
    }
    return 0
}
