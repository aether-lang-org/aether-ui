// spec_themes_demo.ae — AeCS (Aether Cascading Styles) over the AetherUIDriver.
// Proves the swiby-shaped CSS-alike (docs/design/styling.md):
//   * a sheet's ELEMENT rule styles every widget of that kind ("text" →
//     Owner: label), read back from the BACKEND ("fg" in the widget JSON is
//     the last color the platform was actually given, not the DSL model);
//   * a CLASS rule beats the element rule (the "header"-classed heading gets
//     header.text's color, not text's);
//   * a CONTAINER rule paints the stacks ("bg");
//   * re-applying a different sheet RE-THEMES the live tree (the swiby
//     banking-demo move) — the same widgets flip to the green theme's colors.
//
// Run via ci.sh / spec_matrix, or by hand:
//   AETHER_UI_TEST_PORT=9222 ./target/build/examples/themes_demo/bin/themes_demo &
//   UI_SPEC=themes_demo/spec_themes_demo tests/run_spec.sh
import aeocha
import uidriver
import std.string

main() {
    fw = aeocha.init()
    uidriver.wait_server()

    aeocha.describe(fw, "stylesheet theming over AetherUIDriver") {
        aeocha.it("starts unthemed (no explicit colors)") callback {
            h = uidriver.widget_id_by_text("Accounts")
            aeocha.assert_gt(h, 0, "heading found")
            b = uidriver.get_body("/widget/${h}")
            styled = string.contains(b, "\"fg\":")
            aeocha.assert_eq(styled, 0, "heading has no explicit fg yet")
        }

        aeocha.it("blue theme: element rule styles plain text (backend readback)") callback {
            t = uidriver.widget_id_by_text("Blue theme")
            uidriver.post_ok("/widget/${t}/click", "apply blue theme")
            ok = uidriver.wait_body_contains("/widgets", "theme: blue", 20)
            aeocha.assert_true(ok, "status flipped")
            o = uidriver.widget_id_by_text("Owner:")
            b = uidriver.get_body("/widget/${o}")
            aeocha.assert_contains(b, "\"fg\":\"#5c458a\"",
                "plain text carries the blue theme's text color")
        }

        aeocha.it("class rule beats element rule — via the SECOND class token") callback {
            // The heading's classes are "banner header": banner has no rules,
            // so this passing proves multi-class resolution reads past the
            // first token (v1.1), as well as class-beats-element.
            h = uidriver.widget_id_by_text("Accounts")
            b = uidriver.get_body("/widget/${h}")
            aeocha.assert_contains(b, "\"fg\":\"#6030bf\"",
                "the header-classed heading gets header.text's color, not text's")
        }

        aeocha.it("id rule beats class and element (#status)") callback {
            s = uidriver.widget_id_by_text("theme: blue")
            aeocha.assert_gt(s, 0, "status label found")
            b = uidriver.get_body("/widget/${s}")
            aeocha.assert_contains(b, "\"fg\":\"#224488\"",
                "the #status id rule wins over text's element color")
        }

        aeocha.it("root font family + weight flow to widgets (readback)") callback {
            h = uidriver.widget_id_by_text("Accounts")
            b = uidriver.get_body("/widget/${h}")
            aeocha.assert_contains(b, "\"fontFamily\":\"monospace\"",
                "blue theme's root family reached the heading")
            aeocha.assert_contains(b, "\"fontWeight\":\"bold\"",
                "header.text's weight applied")
        }

        aeocha.it("container rule paints the stacks") callback {
            ok = uidriver.wait_body_contains("/widgets", "\"bg\":\"#d6cfe6\"", 20)
            aeocha.assert_true(ok, "a container carries the blue theme's bg")
        }

        aeocha.it("applying another sheet re-themes the LIVE tree") callback {
            g = uidriver.widget_id_by_text("Green theme")
            uidriver.post_ok("/widget/${g}/click", "apply green theme")
            ok = uidriver.wait_body_contains("/widgets", "theme: green", 20)
            aeocha.assert_true(ok, "status flipped")
            o = uidriver.widget_id_by_text("Owner:")
            b = uidriver.get_body("/widget/${o}")
            aeocha.assert_contains(b, "\"fg\":\"#738040\"",
                "the same widget now shows the green theme's color")
            h = uidriver.widget_id_by_text("Accounts")
            b2 = uidriver.get_body("/widget/${h}")
            aeocha.assert_contains(b2, "\"fg\":\"#a3bf30\"",
                "the class rule re-resolved too")
        }

        aeocha.it("the reset-sheet convention genuinely reverts (un-bold, family)") callback {
            // green_theme is a FULL restatement: st_weight(...,0) must have
            // UN-bolded the heading and re-familied root — not just recolored.
            h = uidriver.widget_id_by_text("Accounts")
            b = uidriver.get_body("/widget/${h}")
            aeocha.assert_contains(b, "\"fontWeight\":\"normal\"",
                "two-valued weight reverted bold on the re-theme")
            aeocha.assert_contains(b, "\"fontFamily\":\"serif\"",
                "the family followed the new theme")
            s = uidriver.widget_id_by_text("theme: green")
            b2 = uidriver.get_body("/widget/${s}")
            aeocha.assert_contains(b2, "\"fg\":\"#406030\"",
                "the id rule re-resolved to the green theme's value")
        }

        aeocha.it("styles_for_mode picks a sheet for the OS appearance") callback {
            a = uidriver.widget_id_by_text("Auto (mode)")
            uidriver.post_ok("/widget/${a}/click", "apply mode-picked theme")
            ok = uidriver.wait_body_contains("/widgets", "theme: auto", 20)
            aeocha.assert_true(ok, "auto theme applied")
            // Whichever mode the box is in, the pick lands on one of the two
            // sheets — the id rule shows blue's or green's value, never stale.
            s = uidriver.widget_id_by_text("theme: auto")
            b = uidriver.get_body("/widget/${s}")
            hitBlue = string.contains(b, "\"fg\":\"#224488\"")
            hitGreen = string.contains(b, "\"fg\":\"#406030\"")
            aeocha.assert_eq(hitBlue + hitGreen, 1, "exactly one of the pair applied")
        }
    }
    aeocha.run_summary(fw)
}
