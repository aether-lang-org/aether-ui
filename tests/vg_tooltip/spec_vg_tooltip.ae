// spec_vg_tooltip.ae — drives the vg_tooltip example over the AetherUIDriver
// with the DRAWN tooltip path forced (AETHER_UI_TOOLTIP=drawn). Proves the
// in-window tooltip (roadmap item 1, D3): hovering a tooltipped vg shape opens
// a drawn overlay; hovering empty space closes it; a different shape opens a
// fresh one.
//
// The hover is driven via POST /canvas/1/move?x=&y= (which fires the vg hover
// hit-test directly, past the remote-control motion guard). GET /overlays then
// reports the drawn tooltip's presence. Because it draws in-window (no
// xdg_popup), a green run here means the tooltip works on this window system
// and, by construction, on sommelier too.
//
// Run via ci.sh Phase 5c, or by hand:
//   AETHER_UI_TEST_PORT=9222 AETHER_UI_TOOLTIP=drawn \
//     ./target/build/examples/vg_tooltip/bin/vg_tooltip &
//   UI_SPEC=vg_tooltip/spec_vg_tooltip tests/run_spec.sh
import aeocha
import uidriver

main() {
    fw = aeocha.init()
    uidriver.wait_server()

    // viewBox is 100×100; map viewBox coords → canvas px via the real size.
    cw = uidriver.canvas_w()
    ch = uidriver.canvas_h()
    // Red circle at viewBox (30,40); blue square center ~ (75,39).
    circ_x = (cw * 30) / 100
    circ_y = (ch * 40) / 100
    sq_x = (cw * 75) / 100
    sq_y = (ch * 39) / 100

    aeocha.describe(fw, "vg_tooltip drawn-tooltip over AetherUIDriver") {
        aeocha.it("starts with no overlays") callback {
            r = uidriver.get_body("/overlays")
            aeocha.assert_contains(r, "\"count\":0", "no tooltip at startup")
        }

        aeocha.it("hovering the red circle opens a drawn tooltip") callback {
            uidriver.post_ok("/canvas/1/move?x=${circ_x}&y=${circ_y}", "hover circle")
            ok = uidriver.wait_body_contains("/overlays", "\"live\":1", 20)
            aeocha.assert_true(ok, "a drawn tooltip is live over the circle")
        }

        aeocha.it("moving to empty space hides the tooltip") callback {
            uidriver.post_ok("/canvas/1/move?x=2&y=2", "hover empty")
            // No live overlay remains (the only one flips to live:0).
            ok = uidriver.wait_body_contains("/overlays", "\"live\":0", 20)
            aeocha.assert_true(ok, "the tooltip hid off the shape")
            r = uidriver.get_body("/overlays")
            aeocha.assert_contains(r, "\"live\":0", "no live tooltip over blank canvas")
        }

        aeocha.it("hovering the blue square opens a tooltip again") callback {
            uidriver.post_ok("/canvas/1/move?x=${sq_x}&y=${sq_y}", "hover square")
            ok = uidriver.wait_body_contains("/overlays", "\"live\":1", 20)
            aeocha.assert_true(ok, "a drawn tooltip is live over the square")
        }
    }
    aeocha.run_summary(fw)
}
