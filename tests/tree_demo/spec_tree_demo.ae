// spec_tree_demo.ae — hierarchical tree with expand/collapse.
// Roots start collapsed; clicking a disclosure (▸) reveals that node's
// children only; clicking again (▾) hides them. Sibling subtrees are
// independent.
import aeocha
import uidriver
import std.string

// The id of the first disclosure button reading `glyph` (▸ or ▾).
disclosure(glyph: string) -> int {
    return uidriver.widget_id_by_text(glyph)
}

main() {
    fw = aeocha.init()
    uidriver.wait_server()

    aeocha.describe(fw, "tree over AetherUIDriver") {
        aeocha.it("roots render collapsed; children hidden") callback {
            b = uidriver.get_body("/widgets")
            aeocha.assert_contains(b, "\"text\":\"Documents\"", "Documents root")
            aeocha.assert_contains(b, "\"text\":\"Pictures\"", "Pictures root")
            hidden = string.contains(b, "\"text\":\"report.pdf\"")
            aeocha.assert_eq(hidden, 0, "children hidden while collapsed")
        }

        aeocha.it("expanding a node reveals only its children") callback {
            d = disclosure("▸")   // first collapsed node = Documents
            aeocha.assert_gt(d, 0, "a disclosure control exists")
            uidriver.post_ok("/widget/${d}/click", "expand Documents")
            ok = uidriver.wait_body_contains("/widgets", "\"text\":\"report.pdf\"", 20)
            aeocha.assert_true(ok, "Documents' children now visible")
            b = uidriver.get_body("/widgets")
            aeocha.assert_contains(b, "\"text\":\"notes.txt\"", "both children shown")
            // Pictures is still collapsed → its child stays hidden.
            sib = string.contains(b, "\"text\":\"vacation.jpg\"")
            aeocha.assert_eq(sib, 0, "sibling subtree independent (still collapsed)")
        }

        aeocha.it("collapsing hides the children again") callback {
            d = disclosure("▾")   // the now-expanded Documents
            aeocha.assert_gt(d, 0, "the expanded disclosure shows ▾")
            uidriver.post_ok("/widget/${d}/click", "collapse Documents")
            gone = uidriver.wait_body_contains("/widgets", "\"text\":\"report.pdf\"", 3)
            aeocha.assert_eq(gone, 0, "children hidden after collapse")
        }
    }
    aeocha.run_summary(fw)
}
